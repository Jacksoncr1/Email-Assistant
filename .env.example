# Copy to .env for local development.

# Local SQLite path. Use a mounted path or switch the storage adapter for production.
EMAIL_ASSISTANT_DB_PATH=./data/email_assistant.db

# Vercel + Supabase production storage.
# Use the Supabase Transaction pooler connection string for serverless runtimes.
# Example shape:
# postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
EMAIL_ASSISTANT_DATABASE_URL=

# Any long random secret works. In production, keep this in a secret manager.
EMAIL_ASSISTANT_SECRET_KEY=change-me-to-a-long-random-secret

# development or production. Production requires the cryptography package.
EMAIL_ASSISTANT_ENVIRONMENT=development

# local uses the built-in deterministic assistant. openai uses the optional adapter.
EMAIL_ASSISTANT_LLM_PROVIDER=local
EMAIL_ASSISTANT_OPENAI_API_KEY=api key here
EMAIL_ASSISTANT_OPENAI_MODEL=gpt-5o-mini

# Base URL used when generating OAuth callback URLs.
EMAIL_ASSISTANT_PUBLIC_BASE_URL=http://localhost:8000
