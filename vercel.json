{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/ping",
      "destination": "/api/ping"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{tests/**,scripts/**,data/**,.venv/**,__pycache__/**,**/*.pyc,htmlcov/**,.pytest_cache/**}"
    }
  }
}
