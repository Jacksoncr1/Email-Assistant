{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{tests/**,scripts/**,data/**,.venv/**,__pycache__/**,**/*.pyc,htmlcov/**,.pytest_cache/**}"
    }
  }
}
